  "btop": {
    "display:order": 10,
    "icon": "chart-line",
    "color": "#2dd4bf",
    "label": "btop",
    "description": "Full system monitor — processes, CPU, memory, disk, network",
    "blockdef": {
      "meta": {
        "view": "term",
        "controller": "cmd",
        "cmd": "btop",
        "cmd:shell": true,
        "cmd:runonstart": true,
        "cmd:clearonstart": true,
        "cmd:persistent": true,
        "cmd:env": { "TERM": "xterm-256color" }
      }
    }
  },
  "disk-usage": {
    "display:order": 11,
    "icon": "hard-drive",
    "color": "#8b5cf6",
    "label": "disks",
    "description": "Disk space usage across all mounted volumes (refreshes every 30s)",
    "blockdef": {
      "meta": {
        "view": "term",
        "controller": "cmd",
        "cmd": "pwsh.exe -NoLogo -Command \"while($true){Clear-Host; Write-Host '  DISK USAGE' -ForegroundColor Cyan; Write-Host ('  ' + (Get-Date -Format 'HH:mm:ss')) -ForegroundColor DarkGray; Write-Host ''; Get-Volume | Where-Object {$_.DriveLetter -and $_.Size -gt 0} | Format-Table DriveLetter, FileSystemLabel, @{N='Size(GB)';E={[math]::Round($_.Size/1GB,1)}}, @{N='Free(GB)';E={[math]::Round($_.SizeRemaining/1GB,1)}}, @{N='Used%';E={[math]::Round(($_.Size-$_.SizeRemaining)/$_.Size*100,0)}} -AutoSize; Start-Sleep 30}\"",
        "cmd:shell": true,
        "cmd:runonstart": true,
        "cmd:persistent": true
      }
    }
  },

  "docker-stats": {
    "display:order": 20,
    "icon": "brands@docker",
    "color": "#2496ed",
    "label": "docker",
    "description": "Live Docker container stats (local)",
    "blockdef": {
      "meta": {
        "view": "term",
        "controller": "cmd",
        "cmd": "docker stats --format \"table {{.Name}}\t{{.CPUPerc}}\t{{.MemUsage}}\t{{.NetIO}}\"",
        "cmd:shell": true,
        "cmd:runonstart": true,
        "cmd:persistent": true
      }
    }
  },
  "gpu-stats": {
    "display:order": 21,
    "icon": "microchip",
    "color": "#76b900",
    "label": "gpu-term",
    "description": "NVIDIA GPU utilization terminal — refreshes every 5s (requires nvidia-smi)",
    "blockdef": {
      "meta": {
        "view": "term",
        "controller": "cmd",
        "cmd": "nvidia-smi -l 5",
        "cmd:shell": true,
        "cmd:runonstart": true,
        "cmd:persistent": true
      }
    }
  },

